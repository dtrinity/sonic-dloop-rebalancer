# Private key for contract deployment
PRIVATE_KEY=your_private_key_here

# RPC URLs for different networks
SONIC_MAINNET_RPC_URL=https://rpc.soniclabs.com
SONIC_TESTNET_RPC_URL=https://rpc.testnet.soniclabs.com

# Block explorer API keys
SONICSCAN_API_KEY=your_sonicscan_api_key

# Gas reporting (optional)
REPORT_GAS=true

# Contract addresses (update after deployment)
DLOOP_CORE_ADDRESS=0x0000000000000000000000000000000000000000
INCREASE_ODOS_ADDRESS=0x0000000000000000000000000000000000000000
DECREASE_ODOS_ADDRESS=0x0000000000000000000000000000000000000000
ODOS_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
FLASH_LENDER_ADDRESS=0x0000000000000000000000000000000000000000