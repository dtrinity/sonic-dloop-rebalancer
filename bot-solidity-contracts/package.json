{
  "name": "bot-solidity-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:mainnet": "hardhat deploy --network sonic_mainnet",
    "deploy:testnet": "hardhat deploy --network sonic_testnet",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "prettier --write --plugin=prettier-plugin-solidity 'contracts/**/*.sol' && solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/hardhat": "^9.1.0",
    "hardhat": "^2.19.0",
    "hardhat-deploy": "^0.11.0",
    "prettier": "^3.5.0",
    "prettier-plugin-solidity": "^1.4.2",
    "solhint": "^5.0.5",
    "solidity-coverage": "^0.8.14",
    "typescript": "^5.7.3",
    "@openzeppelin/contracts": "^5.2.0"
  }
}