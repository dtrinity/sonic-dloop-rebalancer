# Private key for bot operations
PRIVATE_KEY=your_private_key_here

# Slack notifications (optional)
SLACK_TOKEN=your_slack_token_here
SLACK_CHANNEL=your_slack_channel_here

# Bot-specific configuration
NETWORK=sonic_testnet
LOOP_INTERVAL_SEC=60
DRY_RUN=true
# Node Environment
NODE_ENV=production
# Optional: Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Contract addresses
DLOOP_CORE_ADDRESS=0x0000000000000000000000000000000000000000
INCREASE_ODOS_ADDRESS=0x0000000000000000000000000000000000000000
DECREASE_ODOS_ADDRESS=0x0000000000000000000000000000000000000000
ODOS_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
FLASH_LENDER_ADDRESS=0x0000000000000000000000000000000000000000

# Token configuration
COLLATERAL_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_TOKEN_DECIMALS=18
COLLATERAL_TOKEN_SYMBOL=COLL
DEBT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
DEBT_TOKEN_DECIMALS=18
DEBT_TOKEN_SYMBOL=DEBT

# Minimum subsidy amounts (in token base units)
MIN_SUBSIDY_COLLATERAL_TOKEN=1000000000000000000
MIN_SUBSIDY_DEBT_TOKEN=1000000000000000000

# Rebalance percentage list (in decimal format)
REBALANCE_PERCENTAGE_LIST=1.0,0.9,0.8,0.7,0.6,0.5,0.4,0.3,0.2,0.1

# Transaction retry configuration
MAX_TX_RETRIES_PER_TRIAL=3

# Odos configuration
SLIPPAGE_LIMIT_BPS=100
MAX_PRICE_IMPACT_BPS=1000
EXACT_OUT_INPUT_CAP_BPS=15000
HTTP_TIMEOUT_MS=10000